{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeon.local/schemas/audit-report.schema.json",
  "title": "AuditReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "overall_signal",
    "summary",
    "findings",
    "human_decision_required"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "overall_signal": {
      "enum": [
        "red",
        "amber",
        "green"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "type",
          "severity",
          "authority_id",
          "authority_quote",
          "audited_quote",
          "explanation",
          "recommended_action",
          "confidence",
          "evidence_validated"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "contradiction",
              "continuity_leak",
              "risk",
              "ambiguity",
              "protected_state_violation"
            ]
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "authority_id": {
            "type": "string"
          },
          "authority_quote": {
            "type": "string"
          },
          "audited_quote": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence_validated": {
            "type": "boolean"
          }
        }
      }
    },
    "human_decision_required": {
      "const": true
    }
  }
}
