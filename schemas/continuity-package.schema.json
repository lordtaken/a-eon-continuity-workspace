{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeon.local/schemas/continuity-package.schema.json",
  "title": "ContinuityPackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "title",
    "version",
    "records"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "authority_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "domain",
          "status",
          "severity_if_breached",
          "statement",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "enum": [
              "chronology",
              "character",
              "object",
              "relationship",
              "location",
              "rule",
              "other"
            ]
          },
          "status": {
            "enum": [
              "protected",
              "active",
              "provisional",
              "deprecated"
            ]
          },
          "severity_if_breached": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "document",
              "locator",
              "quote"
            ],
            "properties": {
              "document": {
                "type": "string",
                "minLength": 1
              },
              "locator": {
                "type": "string",
                "minLength": 1
              },
              "quote": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
